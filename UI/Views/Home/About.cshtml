@{
    ViewData["Title"] = "About Suna - German Speaking Clubs Expert";
}
@section Css{
<!-- Animate.css -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
<!-- Custom Styles -->
<style>
    .profile-img {
        border: 5px solid #2c3e50;
        box-shadow: 0 0 20px rgba(0,0,0,0.1);
    }
    .section-title {
        border-bottom: 3px solid #3498db;
        padding-bottom: 10px;
        margin-bottom: 30px;
    }
    .timeline-item {
        position: relative;
        padding-left: 30px;
        margin-bottom: 40px;
    }
    .timeline-item::before {
        content: '';
        position: absolute;
        left: 0;
        top: 5px;
        width: 15px;
        height: 15px;
        background: #3498db;
        border-radius: 50%;
    }
</style>

}

<body data-bs-spy="scroll" data-bs-target="#navbar-about" data-bs-offset="50">
    <!-- Navigation -->
    <nav id="navbar-about" class="navbar navbar-light bg-light">
        <div class="container">
            <ul class="nav nav-pills">
                <li class="nav-item"><a class="nav-link" href="#about">About</a></li>
                <li class="nav-item"><a class="nav-link" href="#experience">Experience</a></li>
                <li class="nav-item"><a class="nav-link" href="#clubs">Speaking Clubs</a></li>
                <li class="nav-item"><a class="nav-link" href="#methods">Methods</a></li>
                <li class="nav-item"><a class="nav-link" href="#privacy">Privacy</a></li>
            </ul>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="about" class="py-5 bg-light">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-4 text-center animate__animated animate__fadeInLeft">
                    <img src="/images/suna-profile.jpg" alt="Suna" class="profile-img img-fluid rounded-circle mb-4">
                </div>
                <div class="col-md-8 animate__animated animate__fadeInRight">
                    <h1 class="display-4">Hello, I'm Suna!</h1>
                    <p class="lead">German Language Expert & Speaking Club Innovator</p>
                    <p class="text-muted">Born in 1965 in Bremen, Germany | Based in Turkey since 1990</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Experience Timeline -->
    <section id="experience" class="py-5">
        <div class="container">
            <h2 class="section-title animate__animated animate__fadeInDown">Professional Journey</h2>
            <div class="timeline">
                <div class="timeline-item animate__animated animate__fadeIn">
                    <h3>🇩🇪 Bremen Roots</h3>
                    <p class="text-muted">1983-1987: Studied Education at Universität Bremen</p>
                </div>
                <!-- More timeline items -->
            </div>
        </div>
    </section>

    <!-- Speaking Clubs Section -->
    <section id="clubs" class="py-5 bg-light">
        <div class="container">
            <h2 class="section-title animate__animated animate__fadeInDown">Speaking Clubs</h2>
            <div class="row g-4">
                <!-- Club Level Cards -->
                <div class="col-md-4 animate__animated animate__fadeInUp" style="animation-delay: 0.2s;">
                    <div class="card h-100 shadow">
                        <div class="card-body">
                            <h3 class="card-title">A1/A2 Foundation</h3>
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item">Daily Conversations</li>
                                <!-- More list items -->
                            </ul>
                        </div>
                    </div>
                </div>
                <!-- More club levels -->
            </div>
        </div>
    </section>

    <!-- Teaching Methods -->
    <section id="methods" class="py-5">
        <div class="container">
            <h2 class="section-title animate__animated animate__fadeInDown">Innovative Teaching Approach</h2>
            <div class="row g-4">
                <div class="col-md-6 animate__animated animate__fadeInLeft">
                    <div class="card h-100">
                        <div class="card-body">
                            <h3><i class="fas fa-comments me-2"></i>Interactive Discussions</h3>
                            <p>Real-world scenarios with immediate feedback...</p>
                        </div>
                    </div>
                </div>
                <!-- More method cards -->
            </div>
        </div>
    </section>

    <!-- Privacy Section -->
    <section id="privacy" class="py-5 bg-light">
        <div class="container animate__animated animate__fadeInUp">
            <h2 class="section-title">Privacy & Account Management</h2>
            <div class="alert alert-info">
                <h4><i class="fas fa-shield-alt me-2"></i>Data Security</h4>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">Secure account creation/deletion process</li>
                    <li class="list-group-item">End-to-end encrypted communications</li>
                    <li class="list-group-item">Regular security audits</li>
                </ul>
            </div>
            <div class="card">
                <div class="card-body">
                    <h3>Account Controls</h3>
                    <p>Full control over your data:</p>
                    <ul>
                        <li>Instant account deletion from profile settings</li>
                        <li>Data export functionality</li>
                        <li>Cookie management preferences</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Initialize Scrollspy
        var scrollSpy = new bootstrap.ScrollSpy(document.body, {
            target: '#navbar-about'
        });

        // Add animation on scroll
        document.addEventListener('DOMContentLoaded', function() {
            const animateElements = document.querySelectorAll('.animate__animated');
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.visibility = 'visible';
                        entry.target.classList.add(entry.target.dataset.animate);
                    }
                });
            }, { threshold: 0.1 });

            animateElements.forEach(element => {
                observer.observe(element);
            });
        });
    </script>
</body>