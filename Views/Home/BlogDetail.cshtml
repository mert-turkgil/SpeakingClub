@model SpeakingClub.Models.BlogDetailViewModel
@inject LanguageService Localizer
@{
    Layout = "_Layout"; // Your shared layout that loads Bootstrap, FontAwesome, animate.css, GSAP, jQuery, etc.
    
    // SEO Settings
    var description = !string.IsNullOrEmpty(Model.Content) 
        ? (Model.Content.Length > 160 
            ? System.Text.RegularExpressions.Regex.Replace(Model.Content.Substring(0, 160), "<.*?>", "") + "..." 
            : System.Text.RegularExpressions.Regex.Replace(Model.Content, "<.*?>", ""))
        : "Read this interesting blog post on SpeakingClub";
    
    ViewData["Title"] = Model.Title + " | SpeakingClub";
    ViewData["Description"] = description;
    ViewData["Keywords"] = string.Join(", ", Model.Tags?.Select(t => t.Name) ?? new List<string>()) + ", German learning, Almanca";
    ViewData["OgType"] = "article";
    ViewData["OgImage"] = !string.IsNullOrEmpty(Model.Image) 
        ? $"https://almanca-konus.com{Model.Image}" 
        : "https://almanca-konus.com/img/header_logo.png";
    
    // Canonical URL
    var canonicalUrl = $"https://almanca-konus.com{Context.Request.Path}";
    ViewData["Canonical"] = canonicalUrl;
    
    // Share URLs
    var encodedUrl = System.Net.WebUtility.UrlEncode(canonicalUrl);
    var encodedTitle = System.Net.WebUtility.UrlEncode(Model.Title ?? "Check this out!");
    var facebookShareUrl = $"https://www.facebook.com/sharer/sharer.php?u={encodedUrl}";
    var twitterShareUrl = $"https://twitter.com/intent/tweet?url={encodedUrl}&text={encodedTitle}";
    var whatsappShareUrl = $"https://wa.me/?text={encodedTitle}%20{encodedUrl}";
    var linkedinShareUrl = $"https://www.linkedin.com/sharing/share-offsite/?url={encodedUrl}";
    
    // JSON-LD Structured Data for BlogPosting
    var associatedMedia = Model.Files?.Select(f => new {
        type = "MediaObject",
        name = f.DisplayName,
        contentUrl = $"https://almanca-konus.com/download/{f.FileId}",
        encodingFormat = f.ContentType,
        contentSize = $"{(f.FileSizeBytes / (1024.0 * 1024.0)):F2} MB"
    }).ToList();

    var structuredData = new {
        context = "https://schema.org",
        type = "BlogPosting",
        headline = Model.Title,
        image = !string.IsNullOrEmpty(Model.Image) ? $"https://almanca-konus.com{Model.Image}" : "https://almanca-konus.com/img/header_logo.png",
        datePublished = Model.Date.ToString("yyyy-MM-dd"),
        dateModified = Model.Date.ToString("yyyy-MM-dd"),
        author = new {
            type = "Person",
            name = Model.Author ?? "SpeakingClub"
        },
        publisher = new {
            type = "Organization",
            name = "Almanca Konuşma Kulübü",
            logo = new {
                type = "ImageObject",
                url = "https://almanca-konus.com/img/header_logo.png"
            }
        },
        description = description,
        url = canonicalUrl,
        mainEntityOfPage = new {
            type = "WebPage",
            id = canonicalUrl
        },
        keywords = Model.Tags?.Select(t => t.Name).ToList(),
        associatedMedia = associatedMedia
    };
}
@section Css{
    <!-- JSON-LD Structured Data for SEO -->
    <script type="application/ld+json">
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(structuredData, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }))
    </script>
    
    <style>
        /* Advanced Quiz Section Styling */
        .advanced-quiz-section {
            border-radius: 0.5rem;
            overflow: hidden;
        }
        .advanced-quiz-header {
            padding: 1rem;
        }
        .advanced-quiz-question {
            font-weight: bold;
            font-size: 1.2rem;
        }
        .advanced-quiz-option {
            font-size: 1rem;
            cursor: pointer;
        }
        .advanced-quiz-submit {
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .advanced-quiz-submit:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
        }
        .advanced-quiz-feedback {
            font-size: 1rem;
        }

        /* File attachment cards */
        .file-card:hover {
            transform: translateY(-5px) !important;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15) !important;
        }
    </style>
}
<div class="container py-5">

    <!-- Title Section (full width) -->
    <div class="row bg-fourth shadow-lg rounded p-4 mb-4">
        <div class="col-12 text-center">
            <h1 class="display-4 fw-bold">@Model.Title</h1>
        </div>
    </div>

    <!-- Content and Tags Row -->
    <div class="row my-4">
        <!-- Left Column: Blog Content -->
        <div class="col-md-8">
            <div class="content-body">
                @if (!string.IsNullOrEmpty(Model.Content))
                {
                    @Html.Raw(Model.Content)
                }
                else
                {
                    <p class="text-muted">@Localizer.GetKey("Err2").Value</p>
                }
            </div>
        </div>
        <!-- Right Column: Tags Sidebar -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <i class="fas fa-tags"></i> @Localizer.GetKey("Tag").Value
                </div>
                <div class="card-body">
                    @if (Model.Tags != null && Model.Tags.Any())
                    {
                        <ul class="list-unstyled">
                            @foreach (var tag in Model.Tags)
                            {
                                <li class="badge bg-info text-dark me-1 mb-1">@tag.Name</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted mb-0"> @Localizer.GetKey("Err3").Value </p>
                    }
                </div>
            </div>
        </div>
        @if (Model.Category != null)
        {
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <div class="badge bg-primary">@Model.Category.Name</div>
                </div>
            </div>
        </div>
        }
    </div>

@if (Model.QuizQuestion != null)
{
    <!-- Quiz Section (full width) -->
    <div class="advanced-quiz-section card shadow-lg my-4">
    <div class="card-header advanced-quiz-header bg-primary text-white">
        <h5 class="mb-0">Quiz Challenge</h5>
    </div>        
    <div class="card-body">
        <!-- Display the quiz question -->
            <h6 class="advanced-quiz-question mb-3">@Model.QuizQuestion.QuestionText</h6>
            <form id="advancedQuizForm">
                @foreach (var answer in Model.QuizQuestion.Answers)
                {
                    <div class="form-check advanced-quiz-option mb-2">
                        <input class="form-check-input" type="radio" name="advancedQuizAnswer" id="advancedQuizAnswer_@answer.Id" value="@answer.Id" />
                        <label class="form-check-label" for="advancedQuizAnswer_@answer.Id">
                            @answer.AnswerText
                        </label>
                    </div>
                }
                <button type="submit" class="btn btn-success advanced-quiz-submit mt-3">
                    @Localizer.GetKey("SubmitAnswer").Value <i class="fa-solid fa-check ms-1"></i>
                </button>
            </form>
            <div id="advancedQuizFeedback" class="advanced-quiz-feedback mt-3" style="display: none;"></div>
            </div>
</div>
}
    
    @if (Model.Files != null && Model.Files.Any())
    {
        var attachmentsTitle = Localizer.GetKey("Attachments")?.Value ?? "Downloadable Files";
        var totalFiles = Model.Files.Count();
        <!-- Downloadable Files Section -->
        <div class="row my-4">
            <div class="col-12">
                <div class="card shadow-sm border-0" style="border-radius: 16px; overflow: hidden;">
                    <!-- Header with gradient -->
                    <div class="card-header border-0 py-3 px-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0 text-white fw-bold">
                                <i class="fa-solid fa-folder-open me-2"></i> @attachmentsTitle
                            </h5>
                            <span class="badge bg-white text-dark rounded-pill px-3 py-2" style="font-size: 0.85rem;">
                                @totalFiles @(totalFiles == 1 ? "file" : "files")
                            </span>
                        </div>
                    </div>
                    <div class="card-body p-4" style="background: #fafbff;">
                        <div class="row g-4">
                            @foreach (var file in Model.Files)
                            {
                                var iconClass = file.FileExtension switch
                                {
                                    ".pdf" => "fa-file-pdf",
                                    ".doc" or ".docx" => "fa-file-word",
                                    ".xls" or ".xlsx" => "fa-file-excel",
                                    ".ppt" or ".pptx" => "fa-file-powerpoint",
                                    _ => "fa-file"
                                };
                                var iconColor = file.FileExtension switch
                                {
                                    ".pdf" => "#dc3545",
                                    ".doc" or ".docx" => "#2b579a",
                                    ".xls" or ".xlsx" => "#217346",
                                    ".ppt" or ".pptx" => "#d24726",
                                    _ => "#6c757d"
                                };
                                var bgGradient = file.FileExtension switch
                                {
                                    ".pdf" => "linear-gradient(135deg, #fff5f5 0%, #ffe3e3 100%)",
                                    ".doc" or ".docx" => "linear-gradient(135deg, #e8f0fe 0%, #d0e1fd 100%)",
                                    ".xls" or ".xlsx" => "linear-gradient(135deg, #e6f9ef 0%, #c8f0d8 100%)",
                                    ".ppt" or ".pptx" => "linear-gradient(135deg, #fef3e8 0%, #fde2cc 100%)",
                                    _ => "linear-gradient(135deg, #f0f0f0 0%, #e0e0e0 100%)"
                                };
                                var typeBadge = file.FileExtension?.TrimStart('.').ToUpper();
                                var sizeMB = (file.FileSizeBytes / (1024.0 * 1024.0)).ToString("F2");
                                var isPdf = file.FileExtension?.ToLower() == ".pdf";

                                <div class="col-md-6 col-lg-4">
                                    <div class="card h-100 border-0 shadow-sm file-card" style="border-radius: 14px; overflow: hidden; transition: all 0.3s ease;">
                                        <!-- Preview Area -->
                                        @if (isPdf)
                                        {
                                            <div style="height: 200px; overflow: hidden; position: relative; background: @bgGradient;">
                                                <iframe src="@file.StoredFilePath#toolbar=0&navpanes=0&scrollbar=0"
                                                        style="width: 100%; height: 100%; border: none; pointer-events: none;"
                                                        title="@file.DisplayName preview"></iframe>
                                                <div style="position: absolute; top: 10px; right: 10px;">
                                                    <span class="badge rounded-pill shadow-sm" style="background: @iconColor; font-size: 0.75rem; padding: 5px 12px;">
                                                        <i class="fa-solid @iconClass me-1"></i> @typeBadge
                                                    </span>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex align-items-center justify-content-center position-relative" style="height: 200px; background: @bgGradient;">
                                                <div class="text-center">
                                                    <i class="fa-solid @iconClass" style="font-size: 4.5rem; color: @iconColor; opacity: 0.85;"></i>
                                                    <div class="mt-2">
                                                        <span class="badge rounded-pill shadow-sm" style="background: @iconColor; font-size: 0.75rem; padding: 5px 12px;">
                                                            @typeBadge
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        }

                                        <!-- File Info -->
                                        <div class="card-body p-3">
                                            <h6 class="card-title fw-bold mb-1 text-truncate" title="@file.DisplayName" style="color: #2d3748;">
                                                @file.DisplayName
                                            </h6>
                                            <p class="text-muted mb-3" style="font-size: 0.82rem;">
                                                @sizeMB MB
                                            </p>
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span class="text-muted" style="font-size: 0.82rem;">
                                                    <i class="fa-solid fa-arrow-down"></i>
                                                    <span id="download-count-@file.FileId">@file.DownloadCount</span>
                                                </span>
                                                <a href="/download/@file.FileId" class="btn btn-sm px-3 py-1 fw-semibold text-white"
                                                   style="background: @iconColor; border-radius: 20px; font-size: 0.85rem; transition: all 0.2s ease;"
                                                   onclick="incrementCount(@file.FileId)" rel="nofollow"
                                                   onmouseover="this.style.opacity='0.85'; this.style.transform='scale(1.05)'"
                                                   onmouseout="this.style.opacity='1'; this.style.transform='scale(1)'">
                                                    <i class="fa-solid fa-download me-1"></i> Download
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }


    <!-- Blog Cover Section (full width) -->
    <div class="row my-5">
        <div class="col-12 justify-content-center text-center">
            @if (!string.IsNullOrEmpty(Model.Image))
            {
                <img src="@Model.Image" alt="@Model.Title" class="img-fluid rounded shadow-lg" />
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center bg-secondary text-white rounded" style="height: 300px;">
                    <i class="fas fa-image fa-3x"></i>
                    <span class="ms-3 fs-2">@Localizer.GetKey("Err4").Value</span>
                </div>
            }
        </div>
    </div>

    <!-- Author and Meta Information (full width) -->
    <div class="row my-4">
        <div class="col-12 text-center">
            <p class="text-muted">
                <span><i class="fa-solid fa-eye"></i> @Model.ViewCount </span>
                 &nbsp; | &nbsp;
                <i class="far fa-calendar-alt"></i> @Model.Date.ToString("MMMM dd, yyyy")
                 &nbsp; | &nbsp;
                @if (!string.IsNullOrEmpty(Model.Author))
                {
                    <span class="ms-3"><i class="far fa-user"></i> @Model.Author</span>
                }
            </p>
        </div>
    </div>
    
    <!-- Social Sharing Section -->
    <div class="row my-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h6 class="mb-3"><i class="fas fa-share-alt me-2"></i>@Localizer.GetKey("ShareThisPost").Value</h6>
                    <div class="d-flex justify-content-center gap-3 flex-wrap">
                        <!-- Facebook Share -->
                        <a href="@facebookShareUrl" target="_blank" rel="noopener noreferrer" 
                           class="btn btn-primary btn-lg rounded-circle" 
                           style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;"
                           title="Share on Facebook">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                        
                        <!-- Twitter/X Share -->
                        <a href="@twitterShareUrl" target="_blank" rel="noopener noreferrer"
                           class="btn btn-dark btn-lg rounded-circle"
                           style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;"
                           title="Share on X (Twitter)">
                            <i class="fab fa-x-twitter"></i>
                        </a>
                        
                        <!-- WhatsApp Share -->
                        <a href="@whatsappShareUrl" target="_blank" rel="noopener noreferrer"
                           class="btn btn-success btn-lg rounded-circle"
                           style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;"
                           title="Share on WhatsApp">
                            <i class="fab fa-whatsapp"></i>
                        </a>
                        
                        <!-- LinkedIn Share -->
                        <a href="@linkedinShareUrl" target="_blank" rel="noopener noreferrer"
                           class="btn btn-lg rounded-circle"
                           style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; background-color: #0A66C2; color: white;"
                           title="Share on LinkedIn">
                            <i class="fab fa-linkedin-in"></i>
                        </a>
                        
                        <!-- Instagram Copy Link (Instagram doesn't support direct sharing) -->
                        <button type="button" 
                                class="btn btn-lg rounded-circle copy-link-btn"
                                style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; background: linear-gradient(45deg, #f09433 0%,#e6683c 25%,#dc2743 50%,#cc2366 75%,#bc1888 100%); color: white; border: none;"
                                title="Copy link for Instagram"
                                data-url="@canonicalUrl">
                            <i class="fab fa-instagram"></i>
                        </button>
                        
                        <!-- Copy Link Button -->
                        <button type="button" 
                                class="btn btn-secondary btn-lg rounded-circle copy-link-btn"
                                style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;"
                                title="Copy Link"
                                data-url="@canonicalUrl">
                            <i class="fas fa-link"></i>
                        </button>
                    </div>
                    <small class="text-muted mt-2 d-block" id="copyFeedback" style="display: none !important;"></small>
                </div>
            </div>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(Model.RawYT) || !string.IsNullOrEmpty(Model.RawMaps))
    {
        <div class="row my-5">
            @* Render YouTube iframe if RawYT is not null/empty *@
            @if (!string.IsNullOrEmpty(Model.RawYT))
            {
                <div class="col-6">
                    <iframe
                            src="@Model.RawYT" 
                            title="YouTube video player"
                            width="100%"
                            style="height: 450px;" 
                            frameborder="0" 
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                            referrerpolicy="strict-origin-when-cross-origin" 
                            allowfullscreen>
                    </iframe>
                </div>
            }
            
            @* Render Google Maps iframe if RawMaps is not null/empty *@
            @if (!string.IsNullOrEmpty(Model.RawMaps))
            {
                <div class="col-6">
                    <iframe src="@Model.RawMaps" 
                            style="border:0;"
                            height="100%" 
                            width="100%"
                            allowfullscreen="" 
                            loading="lazy" 
                            referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script src="~/lib/gsap/gsap.min.js"></script>
    <script>
        // Copy link functionality for Instagram and general copy
        document.querySelectorAll('.copy-link-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var url = this.getAttribute('data-url');
                navigator.clipboard.writeText(url).then(function() {
                    var feedback = document.getElementById('copyFeedback');
                    feedback.textContent = '@Localizer.GetKey("LinkCopied").Value';
                    feedback.style.display = 'block !important';
                    feedback.classList.remove('d-none');
                    feedback.style.cssText = 'display: block !important;';
                    setTimeout(function() {
                        feedback.style.cssText = 'display: none !important;';
                    }, 2000);
                }).catch(function(err) {
                    console.error('Failed to copy: ', err);
                    alert('Failed to copy link. Please copy manually: ' + url);
                });
            });
        });
        
        @if (Model.QuizQuestion != null)
        {
            // When the advanced quiz form is submitted.
            <text>
            document.getElementById("advancedQuizForm")?.addEventListener("submit", function (e) {
                e.preventDefault();

                // Retrieve the selected answer.
                const selectedRadio = document.querySelector('input[name="advancedQuizAnswer"]:checked');
                const feedbackDiv = document.getElementById("advancedQuizFeedback");

                if (!selectedRadio) {
                    feedbackDiv.innerHTML = "<div class='alert alert-warning animate__animated animate__shakeX'>Please select an answer.</div>";
                    feedbackDiv.style.display = "block";
                    return;
                }

                // Parse the selected answer id.
                const selectedAnswerId = parseInt(selectedRadio.value, 10);

                // Provide the correct answer id and text directly from the Model.
                const correctAnswerId = @Model.QuizQuestion.Answers.First(a => a.IsCorrect).Id;
                const correctAnswerText = "@Model.QuizQuestion.Answers.First(a => a.IsCorrect).AnswerText";

                // Show animated feedback.
                if (selectedAnswerId === correctAnswerId) {
                    feedbackDiv.innerHTML = "<div class='alert alert-success animate__animated animate__fadeIn'>Correct! Congratulations.</div>";
                } else {
                    feedbackDiv.innerHTML = "<div class='alert alert-danger animate__animated animate__fadeIn'>Incorrect. The correct answer is: <strong>" + correctAnswerText + "</strong></div>";
                }
                feedbackDiv.style.display = "block";
            });
            </text>
        }

        // Increment download count display
        function incrementCount(fileId) {
            var el = document.getElementById('download-count-' + fileId);
            if (el) {
                el.textContent = parseInt(el.textContent) + 1;
            }
        }

        // After login redirect: auto-start download and clean the URL
        (function () {
            var params = new URLSearchParams(window.location.search);
            var fileId = params.get('autoDownload');
            if (fileId) {
                // Strip the param from the URL first so refresh won't re-trigger
                params.delete('autoDownload');
                var clean = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
                window.history.replaceState({}, '', clean);
                // Navigate to download URL — browser stays on page because the
                // server responds with Content-Disposition: attachment
                window.location.href = '/download/' + fileId;
            }
        })();
    </script>
}
