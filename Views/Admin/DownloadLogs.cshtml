@model List<SpeakingClub.Entity.DownloadLog>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Download Logs";
}

@section Css{
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css"
          onerror="this.onerror=null;this.href='/css/dataTables.bootstrap5.min.css'">
}

<section class="container-xxl my-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h3 class="card-title mb-0"><i class="fa-solid fa-download me-2"></i>Download Logs</h3>
            <a href="@Url.Action("Index", "Admin")" class="btn btn-light btn-sm">
                <i class="fas fa-arrow-left me-1"></i> Back to Admin
            </a>
        </div>
        <div class="card-body">
            <form method="get" class="row g-2 mb-3">
                <div class="col-md-4">
                    <input type="text" name="searchTerm" class="form-control" placeholder="Search by user, email, or file name..."
                           value="@ViewBag.SearchTerm" />
                </div>
                <div class="col-md-3">
                    <select name="sortBy" class="form-select">
                        <option value="">Newest first</option>
                        <option value="oldest" selected="@(ViewBag.SortBy == "oldest")">Oldest first</option>
                        <option value="user" selected="@(ViewBag.SortBy == "user")">By user</option>
                        <option value="file" selected="@(ViewBag.SortBy == "file")">By file name</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search me-1"></i>Filter</button>
                </div>
            </form>

            @if (!Model.Any())
            {
                <div class="alert alert-info">No download logs found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>User</th>
                                <th>Email</th>
                                <th>File</th>
                                <th>Downloaded At (UTC)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int rowNum = (ViewBag.CurrentPage - 1) * 50; }
                            @foreach (var log in Model)
                            {
                                rowNum++;
                                <tr>
                                    <td>@rowNum</td>
                                    <td>@log.UserFullName</td>
                                    <td>@log.UserEmail</td>
                                    <td>@log.FileName</td>
                                    <td>@log.DownloadedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (ViewBag.TotalPages > 1)
                {
                    <nav>
                        <ul class="pagination justify-content-center">
                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link"
                                       href="@Url.Action("DownloadLogs", "Admin", new { page = i, searchTerm = ViewBag.SearchTerm, sortBy = ViewBag.SortBy })">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</section>
